{
  "manifest_version": 3,
  "name": "TabPrompter",
  "version": "0.1.0",
  "description": "Turns Ultimate Guitar chord pages into a full-screen lyrics and chords teleprompter.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "icons/icon128.png"
      ],
      "matches": [
        "https://*.ultimate-guitar.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.ultimate-guitar.com/*"
      ],
      "css": [
        "teleprompter.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
